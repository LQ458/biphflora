# Local development only. Never place production credentials or URLs here.
MONGODB_URL=mongodb://127.0.0.1:27017/biphflora_demo
REDIS_URL=redis://127.0.0.1:6379
MONGODB_PORT=27017
REDIS_PORT=6379

HOST=127.0.0.1
PORT=3001
secret=replace-with-a-local-only-jwt-secret

REQUEST_LOG_ENABLED=false
AUDIT_EVENTS_ENABLED=false
AUDIT_HASH_SECRET=replace-with-a-local-only-audit-secret
SEARCH_TELEMETRY_ENABLED=false

# Export this value when starting the React client from client/.
REACT_APP_Source_URL=http://127.0.0.1:3001
REACT_APP_SEARCH_TELEMETRY_ENABLED=false
