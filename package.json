{
  "name": "biphflora",
  "version": "3.0.0",
  "description": "Bilingual campus biodiversity catalog with multilingual search, moderated contributions, and responsive media delivery",
  "main": "server.js",
  "scripts": {
    "start": "nodemon server.js",
    "test": "npm run test:backend",
    "test:backend": "node --test --test-concurrency=1 test/*.test.js",
    "lint:frontend": "npm --prefix client run lint",
    "test:frontend": "npm --prefix client test -- --watchAll=false --runInBand",
    "build": "npm --prefix client run build",
    "verify": "npm run test:backend && npm run lint:frontend && npm run test:frontend && npm run build",
    "audit:production": "npm audit --omit=dev --audit-level=high --registry=https://registry.npmjs.org && npm --prefix client audit --omit=dev --audit-level=high --registry=https://registry.npmjs.org",
    "dev:services": "docker compose up -d",
    "dev:services:down": "docker compose down",
    "seed:demo": "node scripts/seed-demo-data.js",
    "reset:demo": "node scripts/reset-demo-data.js",
    "dev:clean": "npm run reset:demo && docker compose down --volumes",
    "evidence:media": "node scripts/collect-media-metrics.js",
    "evidence:product": "node scripts/collect-product-metrics.js",
    "evidence:search-performance": "node scripts/benchmark-search.js",
    "evidence:traffic": "node scripts/collect-traffic-metrics.js",
    "evidence:traffic:snapshot": "node scripts/snapshot-traffic-metrics.js",
    "media:backfill": "node scripts/backfill-media-variants.js",
    "format": "prettier --write ."
  },
  "keywords": [
    "biodiversity",
    "plant-catalog",
    "react",
    "express",
    "mongodb"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.6",
    "compression": "^1.7.5",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "fuse.js": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "moment-timezone": "^0.5.46",
    "mongoose": "^8.24.1",
    "multer": "2.2.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.8.4",
    "react-player": "^3.3.3",
    "redis": "^4.7.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "prettier": "^3.3.3"
  },
  "overrides": {
    "asn1.js": {
      "bn.js": "4.12.3"
    },
    "express": {
      "path-to-regexp": "0.1.13"
    },
    "picomatch": "2.3.2"
  }
}
