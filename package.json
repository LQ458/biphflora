{
  "name": "biphflora",
  "version": "3.0.0",
  "description": "Private plant and bird catalog with community contribution workflows",
  "main": "index.js",
  "scripts": {
    "start": "nodemon app.js",
    "test": "npm run test:backend",
    "test:backend": "node --test --test-concurrency=1 test/*.test.js",
    "test:frontend": "npm --prefix client test -- --watchAll=false --runInBand",
    "build": "npm --prefix client run build",
    "verify": "npm run test:backend && npm run test:frontend && npm run build",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.6",
    "compression": "^1.7.5",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "fuse.js": "^7.0.0",
    "jsonwebtoken": "^9.0.3",
    "moment-timezone": "^0.5.46",
    "mongoose": "^8.24.1",
    "multer": "1.4.5-lts.1",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primereact": "^10.8.4",
    "react-player": "^3.3.3",
    "redis": "^4.7.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prettier": "^3.3.3"
  },
  "overrides": {
    "asn1.js": {
      "bn.js": "4.12.3"
    },
    "express": {
      "path-to-regexp": "0.1.13"
    }
  }
}
